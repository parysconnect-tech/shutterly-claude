# --- Core ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-32-char-secret-with-openssl-rand-base64-32"

# --- Database ---
# Local dev (SQLite, free, zero config)
DATABASE_URL="file:./prisma/shutterly.db"
# Production examples:
# DATABASE_URL="mysql://user:pass@host:3306/shutterly"
# DATABASE_URL="postgresql://user:pass@host:5432/shutterly"

# --- Uploads ---
# Local filesystem (default). Override to use Cloudinary/S3 in prod.
UPLOAD_DRIVER="local"
UPLOAD_DIR="./public/uploads"
UPLOAD_MAX_MB="20"

# Optional Cloudinary (free tier, recommended for prod)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- WordPress bridge ---
WP_BASE_URL="https://your-wp-site.com"
WP_ORIGIN="https://your-wp-site.com"
WP_SHARED_SECRET="generate-another-32-char-secret"
WP_JWT_AUTH_ENABLED="false"

# --- Email (Resend free tier or SMTP) ---
EMAIL_FROM="Shutterly <hello@shutterly.co.za>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# --- Admin ---
# First account with this email becomes super-admin and unlocks the setup wizard.
ADMIN_BOOTSTRAP_EMAIL="you@example.com"

# --- Localisation ---
DEFAULT_LOCALE="en"
SUPPORTED_LOCALES="en,af"
